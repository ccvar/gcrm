{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GCRM Pilot",
  "version": "0.3.0",
  "identifier": "com.ccvar.crm.pilot",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GCRM Pilot",
        "width": 960,
        "height": 640,
        "minWidth": 820,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ccvar/gcrm/releases/download/pilot-latest/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDREQ0U2OEU1MzUzNTEyOUEKUldTYUVqVTE1V2pPVGY2SWJtZ2ZaRlVZdHFIQ0ZUM1hpZDBidGM2TVBPTXZDY0xzWVJvNmk0SmkK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "app",
      "dmg",
      "nsis"
    ],
    "category": "Business",
    "shortDescription": "CCVAR CRM 转化驾驶舱桌面端",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-"
    },
    "windows": {
      "nsis": {
        "languages": [
          "SimpChinese",
          "English"
        ]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
